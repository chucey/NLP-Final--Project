        "import os\n",
        "\n",
        "REPO_URL = \"https://github.com/chucey/NLP-Final--Project.git\"\n",
        "REPO_DIR = \"/content/NLP-Final--Project\"\n",
        "BRANCH_NAME = \"ali\"\n",
