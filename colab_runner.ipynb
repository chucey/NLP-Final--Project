        "    !cd {REPO_DIR} && git checkout {BRANCH_NAME} && git pull\n",
        "else:\n",
        "    print(\"📥 Cloning repository...\")\n",
        "    !git clone {REPO_URL} {REPO_DIR}\n",
        "    !cd {REPO_DIR} && git checkout {BRANCH_NAME} && git pull\n",
